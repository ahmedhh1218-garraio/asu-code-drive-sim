<?xml version="1.0"?>
<!-- Differential-drive car with five ray (lidar-style) distance sensors. -->
<sdf version="1.8">
  <model name="car">
    <pose>0 0 0.05 0 0 0</pose>

    <!-- Chassis -->
    <link name="chassis">
      <pose>0 0 0.05 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="collision"><geometry><box><size>0.2 0.15 0.05</size></box></geometry></collision>
      <visual name="visual">
        <geometry><box><size>0.2 0.15 0.05</size></box></geometry>
        <material><diffuse>0.9 0.2 0.2 1</diffuse></material>
      </visual>

      <!-- Distance sensors: name maps to app/config.py SENSOR_NAMES -->
      <sensor name="front" type="gpu_lidar">
        <pose>0.1 0 0.05 0 0 0</pose>
        <update_rate>10</update_rate>
        <topic>car/sensors/front</topic>
        <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
          <range><min>0.02</min><max>2.0</max><resolution>0.01</resolution></range></lidar>
      </sensor>
      <sensor name="front_left" type="gpu_lidar">
        <pose>0.1 0.05 0.05 0 0 0.785</pose>
        <update_rate>10</update_rate>
        <topic>car/sensors/front_left</topic>
        <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
          <range><min>0.02</min><max>2.0</max><resolution>0.01</resolution></range></lidar>
      </sensor>
      <sensor name="front_right" type="gpu_lidar">
        <pose>0.1 -0.05 0.05 0 0 -0.785</pose>
        <update_rate>10</update_rate>
        <topic>car/sensors/front_right</topic>
        <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
          <range><min>0.02</min><max>2.0</max><resolution>0.01</resolution></range></lidar>
      </sensor>
      <sensor name="left" type="gpu_lidar">
        <pose>0 0.075 0.05 0 0 1.571</pose>
        <update_rate>10</update_rate>
        <topic>car/sensors/left</topic>
        <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
          <range><min>0.02</min><max>2.0</max><resolution>0.01</resolution></range></lidar>
      </sensor>
      <sensor name="right" type="gpu_lidar">
        <pose>0 -0.075 0.05 0 0 -1.571</pose>
        <update_rate>10</update_rate>
        <topic>car/sensors/right</topic>
        <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
          <range><min>0.02</min><max>2.0</max><resolution>0.01</resolution></range></lidar>
      </sensor>
    </link>

    <!-- Wheels -->
    <link name="left_wheel">
      <pose>0 0.09 0.03 -1.5707 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
      <collision name="collision"><geometry><cylinder><radius>0.03</radius><length>0.02</length></cylinder></geometry></collision>
      <visual name="visual"><geometry><cylinder><radius>0.03</radius><length>0.02</length></cylinder></geometry><material><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
    </link>
    <link name="right_wheel">
      <pose>0 -0.09 0.03 -1.5707 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
      <collision name="collision"><geometry><cylinder><radius>0.03</radius><length>0.02</length></cylinder></geometry></collision>
      <visual name="visual"><geometry><cylinder><radius>0.03</radius><length>0.02</length></cylinder></geometry><material><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
    </link>
    <!-- Passive caster -->
    <link name="caster">
      <pose>-0.08 0 0.02 0 0 0</pose>
      <inertial><mass>0.05</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
      <collision name="collision"><geometry><sphere><radius>0.02</radius></sphere></geometry></collision>
      <visual name="visual"><geometry><sphere><radius>0.02</radius></sphere></geometry></visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent><child>left_wheel</child>
      <!-- Axis expressed in the model frame so the wheel rolls about the
           lateral (Y) axis instead of spinning about itself. -->
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
    </joint>
    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent><child>right_wheel</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
    </joint>
    <joint name="caster_joint" type="ball">
      <parent>chassis</parent><child>caster</child>
    </joint>

    <!-- Differential drive: subscribes to /cmd_vel -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.18</wheel_separation>
      <wheel_radius>0.03</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
    </plugin>
  </model>
</sdf>
